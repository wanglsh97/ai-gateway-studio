generator client {
  provider               = "prisma-client"
  output                 = "../apps/api/src/generated/prisma"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
  importFileExtension    = ""
}

datasource db {
  provider = "postgresql"
}

enum RequestCapability {
  CHAT
  IMAGE
  PROMPT
  AGENT
}

enum RequestStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum ImageTaskStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum AdminAuditAction {
  CREATE
  UPDATE
  DELETE
}

enum AgentRunStatus {
  RUNNING
  CANCELLING
  SUCCEEDED
  FAILED
  CANCELLED
  LIMIT_REACHED
  INTERRUPTED
}

enum AgentRunLimitReason {
  MODEL_CALLS
  TOOL_CALLS
  WEB_FETCH_CALLS
  DURATION
  CONTEXT_WINDOW
  SANDBOX_DURATION
  SHELL_CALLS
  SANDBOX_OUTPUT
  SANDBOX_EGRESS
  SANDBOX_RESOURCE
}

enum AgentMessageRole {
  USER
  ASSISTANT
  TOOL
}

enum AgentToolCallStatus {
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum SkillStatus {
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  DELISTED
}

enum SkillReviewDecision {
  APPROVED
  REJECTED
}

enum UserFileDirection {
  INPUT
  OUTPUT
}

enum UserFileStatus {
  PENDING_UPLOAD
  AVAILABLE
  DELETING
  CLEANUP_PENDING
  DELETED
}

enum SkillUploadSessionStatus {
  PENDING_UPLOAD
  FINALIZED
  ABANDONED
}

enum ObjectCleanupStatus {
  NONE
  PENDING
  SUCCEEDED
}

model User {
  id             String                @id @default(uuid()) @db.Uuid
  githubId       String                @unique @db.VarChar(32)
  githubUsername String                @db.VarChar(39)
  displayName    String?               @db.VarChar(255)
  avatarUrl      String?               @db.VarChar(2048)
  email          String?               @db.VarChar(320)
  lastLoginAt    DateTime              @db.Timestamptz(3)
  createdAt      DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime              @updatedAt @db.Timestamptz(3)
  sessions       UserSession[]
  requestLogs    RequestLog[]
  imageTasks     ImageGenerationTask[]
  agentThreads   AgentThread[]
  agentRuns      AgentRun[]
  agentSkills    UserAgentSkill[]
  ownedSkills    Skill[]               @relation("SkillOwner")
  files          UserFile[]
  skillUploads   SkillUploadSession[]

  @@index([githubUsername])
  @@index([createdAt])
}

model SkillUploadSession {
  id                  String                   @id @default(uuid()) @db.Uuid
  userId              String                   @db.Uuid
  objectKey           String                   @unique @db.VarChar(1024)
  status              SkillUploadSessionStatus @default(PENDING_UPLOAD)
  cleanupStatus       ObjectCleanupStatus      @default(NONE)
  expectedContentType String                   @db.VarChar(255)
  expectedSizeBytes   BigInt
  expectedSha256      String                   @db.Char(64)
  observedSizeBytes   BigInt?
  observedSha256      String?                  @db.Char(64)
  expiresAt           DateTime                 @db.Timestamptz(3)
  finalizedAt         DateTime?                @db.Timestamptz(3)
  abandonedAt         DateTime?                @db.Timestamptz(3)
  cleanupAttempts     Int                      @default(0)
  cleanupError        String?                  @db.Text
  createdAt           DateTime                 @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime                 @updatedAt @db.Timestamptz(3)
  user                User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([status, expiresAt])
  @@index([cleanupStatus, updatedAt])
}

model UserAgentSkill {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  skillId       String   @db.VarChar(64)
  enabled       Boolean  @default(true)
  marketSkillId String?  @db.Uuid
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketSkill   Skill?   @relation(fields: [marketSkillId], references: [id], onDelete: Restrict)

  @@unique([userId, skillId])
  @@unique([userId, marketSkillId])
  @@index([userId, enabled])
  @@index([skillId])
  @@index([marketSkillId])
}

model Skill {
  id                   String           @id @default(uuid()) @db.Uuid
  name                 String           @unique @db.VarChar(64)
  ownerId              String           @db.Uuid
  title                String           @db.VarChar(120)
  description          String           @db.VarChar(400)
  category             String           @db.VarChar(40)
  status               SkillStatus      @default(PENDING_REVIEW)
  iconObjectKey        String?          @db.VarChar(1024)
  packageObjectKey     String?          @unique @db.VarChar(1024)
  packageSha256        String?          @db.Char(64)
  packageSizeBytes     BigInt?
  skillMarkdown        String?          @db.Text
  fileTree             Json?
  addCount             Int              @default(0)
  publishedAt          DateTime?        @db.Timestamptz(3)
  delistedAt           DateTime?        @db.Timestamptz(3)
  packageUpdatedAt     DateTime?        @db.Timestamptz(3)
  createdAt            DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime         @updatedAt @db.Timestamptz(3)
  owner                User             @relation("SkillOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  reviews              SkillReview[]
  userAdds             UserAgentSkill[]
  agentToolCallRecords AgentToolCall[]

  @@index([status, publishedAt])
  @@index([category, status])
  @@index([ownerId, updatedAt])
  @@index([addCount])
}

model SkillReview {
  id            String              @id @default(uuid()) @db.Uuid
  skillId       String              @db.Uuid
  reviewer      String              @db.VarChar(64)
  decision      SkillReviewDecision
  reason        String?             @db.Text
  packageSha256 String              @db.Char(64)
  createdAt     DateTime            @default(now()) @db.Timestamptz(3)
  skill         Skill               @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@index([skillId, createdAt])
  @@index([reviewer, createdAt])
}

model UserFile {
  id               String            @id @default(uuid()) @db.Uuid
  userId           String            @db.Uuid
  runId            String?           @db.Uuid
  sourceToolCallId String?           @db.Uuid
  direction        UserFileDirection
  status           UserFileStatus    @default(PENDING_UPLOAD)
  name             String            @db.VarChar(255)
  mimeType         String?           @db.VarChar(255)
  objectKey        String            @unique @db.VarChar(1024)
  sizeBytes        BigInt
  sha256           String?           @db.Char(64)
  deletedAt        DateTime?         @db.Timestamptz(3)
  createdAt        DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime          @updatedAt @db.Timestamptz(3)
  user             User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  run              AgentRun?         @relation(fields: [runId], references: [id], onDelete: SetNull)
  sourceToolCall   AgentToolCall?    @relation(fields: [sourceToolCallId], references: [id], onDelete: SetNull)

  @@index([userId, status, createdAt])
  @@index([runId])
  @@index([sourceToolCallId])
}

model UserSession {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  tokenHash  String   @unique @db.Char(64)
  expiresAt  DateTime @db.Timestamptz(3)
  lastSeenAt DateTime @default(now()) @db.Timestamptz(3)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model RequestLog {
  id                String               @id @default(uuid()) @db.Uuid
  requestId         String               @unique @default(uuid()) @db.Uuid
  capability        RequestCapability
  prompt            Json
  modelAlias        String               @db.VarChar(64)
  provider          String?              @db.VarChar(64)
  resolvedModel     String?              @db.VarChar(128)
  providerRequestId String?              @db.VarChar(191)
  status            RequestStatus        @default(PENDING)
  stream            Boolean              @default(false)
  clientIp          String?              @db.VarChar(64)
  startedAt         DateTime             @default(now()) @db.Timestamptz(3)
  firstTokenAt      DateTime?            @db.Timestamptz(3)
  completedAt       DateTime?            @db.Timestamptz(3)
  durationMs        Int?
  failoverFrom      String?              @db.VarChar(64)
  failoverTo        String?              @db.VarChar(64)
  failoverReason    String?              @db.VarChar(255)
  errorCode         String?              @db.VarChar(64)
  errorMessage      String?              @db.Text
  errorDetails      Json?
  metadata          Json?
  createdAt         DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime             @updatedAt @db.Timestamptz(3)
  userId            String               @db.Uuid
  user              User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  agentRunId        String?              @db.Uuid
  agentRun          AgentRun?            @relation(fields: [agentRunId], references: [id], onDelete: SetNull)
  billing           BillingRecord?
  imageTask         ImageGenerationTask?

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([modelAlias, createdAt])
  @@index([capability, createdAt])
  @@index([agentRunId])
}

model BillingRecord {
  id               String     @id @default(uuid()) @db.Uuid
  requestLogId     String     @unique @db.Uuid
  inputTokens      Int?
  outputTokens     Int?
  totalTokens      Int?
  usageUnknown     Boolean    @default(true)
  priceVersion     String?    @db.VarChar(64)
  inputCostCny     Decimal?   @db.Decimal(18, 8)
  outputCostCny    Decimal?   @db.Decimal(18, 8)
  estimatedCostCny Decimal?   @db.Decimal(18, 8)
  createdAt        DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime   @updatedAt @db.Timestamptz(3)
  requestLog       RequestLog @relation(fields: [requestLogId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model ImageGenerationTask {
  id             String          @id @default(uuid()) @db.Uuid
  taskId         String          @unique @default(uuid()) @db.Uuid
  requestLogId   String          @unique @db.Uuid
  providerTaskId String?         @db.VarChar(191)
  prompt         String          @db.Text
  modelAlias     String          @db.VarChar(64)
  provider       String?         @db.VarChar(64)
  resolvedModel  String?         @db.VarChar(128)
  options        Json?
  status         ImageTaskStatus @default(PENDING)
  results        Json?
  errorCode      String?         @db.VarChar(64)
  errorMessage   String?         @db.Text
  lastPolledAt   DateTime?       @db.Timestamptz(3)
  startedAt      DateTime?       @db.Timestamptz(3)
  completedAt    DateTime?       @db.Timestamptz(3)
  createdAt      DateTime        @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(3)
  userId         String          @db.Uuid
  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  requestLog     RequestLog      @relation(fields: [requestLogId], references: [id], onDelete: Cascade)

  @@unique([provider, providerTaskId])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

model AdminAuditLog {
  id          String           @id @default(uuid()) @db.Uuid
  actor       String           @db.VarChar(64)
  action      AdminAuditAction
  targetTable String           @db.VarChar(64)
  targetId    String           @db.VarChar(191)
  beforeData  Json?
  afterData   Json?
  requestId   String?          @db.Uuid
  sourceIp    String?          @db.VarChar(64)
  createdAt   DateTime         @default(now()) @db.Timestamptz(3)

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([targetTable, createdAt])
}

model AgentThread {
  id             String               @id @default(uuid()) @db.Uuid
  userId         String               @db.Uuid
  title          String               @db.VarChar(200)
  modelId        String               @db.VarChar(128)
  provider       String               @db.VarChar(64)
  createdAt      DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime             @updatedAt @db.Timestamptz(3)
  user           User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  messages       AgentMessage[]
  runs           AgentRun[]
  contextSummary AgentContextSummary?

  @@index([userId, updatedAt])
  @@index([userId, createdAt])
}

model AgentContextSummary {
  id                     String      @id @default(uuid()) @db.Uuid
  threadId               String      @unique @db.Uuid
  revision               Int         @default(1)
  coveredThroughSequence Int
  schemaVersion          String      @db.VarChar(32)
  promptHash             String      @db.VarChar(64)
  modelId                String      @db.VarChar(128)
  content                Json
  inputTokens            Int?
  outputTokens           Int?
  totalTokens            Int?
  createdAt              DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime    @updatedAt @db.Timestamptz(3)
  thread                 AgentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}

model AgentMessage {
  id        String           @id @default(uuid()) @db.Uuid
  threadId  String           @db.Uuid
  runId     String?          @db.Uuid
  role      AgentMessageRole
  sequence  Int
  parts     Json
  createdAt DateTime         @default(now()) @db.Timestamptz(3)
  thread    AgentThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)
  run       AgentRun?        @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@unique([threadId, sequence])
  @@index([threadId, createdAt])
  @@index([runId])
}

model AgentRun {
  id                   String               @id @default(uuid()) @db.Uuid
  threadId             String               @db.Uuid
  userId               String               @db.Uuid
  status               AgentRunStatus       @default(RUNNING)
  limitReason          AgentRunLimitReason?
  input                String               @db.Text
  errorCode            String?              @db.VarChar(64)
  errorMessage         String?              @db.Text
  promptProfileVersion String?              @db.VarChar(64)
  promptHash           String?              @db.VarChar(64)
  promptManifest       Json?
  modelCallCount       Int                  @default(0)
  toolCallCount        Int                  @default(0)
  webFetchCount        Int                  @default(0)
  shellCallCount       Int                  @default(0)
  sandboxId            String?              @unique @db.VarChar(191)
  activeSkillManifest  Json?
  fileManifest         Json?
  sandboxUsage         Json?
  sandboxStartedAt     DateTime?            @db.Timestamptz(3)
  sandboxDestroyedAt   DateTime?            @db.Timestamptz(3)
  inputTokens          Int                  @default(0)
  outputTokens         Int                  @default(0)
  totalTokens          Int                  @default(0)
  usageUnknown         Boolean              @default(false)
  estimatedCostCny     Decimal?             @db.Decimal(18, 8)
  lastSequence         Int                  @default(-1)
  startedAt            DateTime?            @db.Timestamptz(3)
  completedAt          DateTime?            @db.Timestamptz(3)
  createdAt            DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime             @updatedAt @db.Timestamptz(3)
  thread               AgentThread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Restrict)
  events               AgentEvent[]
  toolCallRecords      AgentToolCall[]
  messages             AgentMessage[]
  requestLogs          RequestLog[]
  files                UserFile[]

  @@index([threadId, createdAt])
  @@index([userId, status])
}

model AgentEvent {
  id        String   @id @default(uuid()) @db.Uuid
  runId     String   @db.Uuid
  sequence  Int
  type      String   @db.VarChar(64)
  payload   Json
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, sequence])
  @@index([runId, sequence])
}

model AgentToolCall {
  id                 String              @id @default(uuid()) @db.Uuid
  runId              String              @db.Uuid
  toolCallId         String              @db.VarChar(191)
  toolName           String              @db.VarChar(64)
  args               Json
  status             AgentToolCallStatus @default(RUNNING)
  summary            String?             @db.Text
  audit              Json?
  errorCode          String?             @db.VarChar(64)
  errorMessage       String?             @db.Text
  sandboxId          String?             @db.VarChar(191)
  skillId            String?             @db.Uuid
  skillName          String?             @db.VarChar(64)
  packageSha256      String?             @db.Char(64)
  command            String?             @db.Text
  workingDirectory   String?             @db.Text
  exitCode           Int?
  durationMs         Int?
  stdoutBytes        Int?
  stderrBytes        Int?
  stdoutTruncated    Boolean?
  stderrTruncated    Boolean?
  sandboxLimitReason String?             @db.VarChar(64)
  startedAt          DateTime            @default(now()) @db.Timestamptz(3)
  completedAt        DateTime?           @db.Timestamptz(3)
  run                AgentRun            @relation(fields: [runId], references: [id], onDelete: Cascade)
  skill              Skill?              @relation(fields: [skillId], references: [id], onDelete: SetNull)
  files              UserFile[]

  @@unique([runId, toolCallId])
  @@index([runId])
  @@index([skillId])
  @@index([sandboxId])
}
