# Runtime
NODE_ENV=development
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# PostgreSQL / Redis
POSTGRES_DB=aigateway
POSTGRES_USER=aigateway
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://aigateway:change-me-in-production@localhost:5432/aigateway?schema=public
DATABASE_POOL_MAX=10
REDIS_URL=redis://localhost:6379
TRUSTED_PROXY_HOPS=1

# Provider switches: Mock is the only provider enabled during initial setup
MOCK_PROVIDER_ENABLED=true
QWEN_ENABLED=false
GLM_ENABLED=false
DEEPSEEK_ENABLED=false
WANXIANG_ENABLED=false
COGVIEW_ENABLED=false

# Real provider credentials; keep empty while the provider is disabled
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GLM_API_KEY=
DEEPSEEK_API_KEY=
WANXIANG_API_KEY=
COGVIEW_API_KEY=

# Stable alias -> actual provider model id
QWEN_MODEL_ID=
GLM_MODEL_ID=
DEEPSEEK_MODEL_ID=
WANXIANG_MODEL_ID=
COGVIEW_MODEL_ID=
PROMPT_OPTIMIZER_MODEL=qwen

# Initial rate-limit defaults
CHAT_RATE_LIMIT_PER_MINUTE=10
IMAGE_RATE_LIMIT_PER_MINUTE=5
ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=5
CHAT_MAX_TOKENS=4096
