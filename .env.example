# Runtime
NODE_ENV=development
API_PORT=3001
WEB_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# PostgreSQL / Redis
POSTGRES_DB=aigateway
POSTGRES_USER=aigateway
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://aigateway:change-me-in-production@localhost:5432/aigateway?schema=public
DATABASE_POOL_MAX=10
REDIS_URL=redis://localhost:6379
TRUSTED_PROXY_HOPS=1

# GitHub OAuth user authentication. Create a separate OAuth App for local development.
GITHUB_OAUTH_ENABLED=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/github/callback
GITHUB_OAUTH_HTTP_TIMEOUT_MS=10000
USER_SESSION_SECRET=development-only-user-session-secret-change-me
USER_SESSION_TTL_SECONDS=2592000

# Executable Skill and user-file object storage. Keep `memory` for local Mock flows.
SKILL_OBJECT_STORE_DRIVER=memory
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_INTERNAL=false
OSS_TIMEOUT_MS=30000
SKILL_UPLOAD_TTL_SECONDS=300
SKILL_STAGING_CLEANUP_BATCH=100

# Provider switches: Mock is the only provider enabled during initial setup
MOCK_PROVIDER_ENABLED=true
# Agent web_fetch: omit or false = production live fetch; true = deterministic fixture (CI/E2E)
AGENT_WEB_FETCH_FIXTURE=false
QWEN_ENABLED=false
GLM_ENABLED=false
DEEPSEEK_ENABLED=false
KIMI_ENABLED=false
WANXIANG_ENABLED=false
COGVIEW_ENABLED=false

# Real provider credentials; keep empty while the provider is disabled
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
WANXIANG_API_KEY=
WANXIANG_BASE_URL=https://dashscope.aliyuncs.com/api/v1
COGVIEW_API_KEY=
COGVIEW_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Chat 模型目录统一维护在 apps/api/src/chat/chat-models.config.ts，不能通过环境变量覆盖。
QWEN_FALLBACK_ALIAS=
GLM_FALLBACK_ALIAS=
DEEPSEEK_FALLBACK_ALIAS=
KIMI_FALLBACK_ALIAS=
WANXIANG_MODEL_ID=
COGVIEW_MODEL_ID=
PROMPT_OPTIMIZER_MODEL=qwen

# Initial rate-limit defaults
CHAT_RATE_LIMIT_PER_MINUTE=10
IMAGE_RATE_LIMIT_PER_MINUTE=5
IMAGE_DOWNLOAD_MAX_BYTES=10000000
ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=5
ADMIN_FIXED_CREDENTIALS_ENABLED=true
ADMIN_SESSION_SECRET=development-only-admin-session-secret-change-me
ADMIN_SESSION_TTL_SECONDS=900
CHAT_MAX_TOKENS=4096
PROVIDER_HEALTH_TTL_SECONDS=300
PROVIDER_HEALTH_FAILURE_THRESHOLD=3
PROVIDER_TIMEOUT_MS=60000
PROVIDER_MAX_CONNECTIONS=20
PRICING_VERSION=dev-v1
QWEN_INPUT_PRICE_CNY_PER_MILLION=
QWEN_OUTPUT_PRICE_CNY_PER_MILLION=
GLM_INPUT_PRICE_CNY_PER_MILLION=
GLM_OUTPUT_PRICE_CNY_PER_MILLION=
DEEPSEEK_INPUT_PRICE_CNY_PER_MILLION=
DEEPSEEK_OUTPUT_PRICE_CNY_PER_MILLION=
KIMI_INPUT_PRICE_CNY_PER_MILLION=
KIMI_OUTPUT_PRICE_CNY_PER_MILLION=
