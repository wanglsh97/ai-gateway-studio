{
  "name": "@aigateway/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "prebuild": "corepack pnpm --workspace-root db:generate",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "pretypecheck": "corepack pnpm --workspace-root db:generate",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:agent-harness": "AGENT_WEB_FETCH_FIXTURE=true tsx scripts/agent-harness.check.ts",
    "test:agent-run": "AGENT_WEB_FETCH_FIXTURE=true tsx --env-file-if-exists=../../.env scripts/agent-run.check.ts",
    "test:agent-e2e": "AGENT_WEB_FETCH_FIXTURE=true MOCK_PROVIDER_ENABLED=true QWEN_ENABLED=false GLM_ENABLED=false DEEPSEEK_ENABLED=false KIMI_ENABLED=false WANXIANG_ENABLED=false COGVIEW_ENABLED=false tsx scripts/agent-e2e.check.ts",
    "test:smoke:deepseek": "tsx --env-file-if-exists=../../.env scripts/deepseek-chat.smoke.ts",
    "test:smoke:glm": "tsx --env-file-if-exists=../../.env scripts/glm-chat.smoke.ts",
    "test:smoke:kimi": "tsx --env-file-if-exists=../../.env scripts/kimi-chat.smoke.ts",
    "test:smoke:qwen": "tsx --env-file-if-exists=../../.env scripts/qwen-chat.smoke.ts",
    "test:smoke:cogview": "tsx --env-file-if-exists=../../.env scripts/cogview-image.smoke.ts",
    "test:smoke:wanxiang": "tsx --env-file-if-exists=../../.env scripts/wanxiang-image.smoke.ts",
    "pretest:e2e": "DATABASE_URL=\"$TEST_DATABASE_URL\" corepack pnpm --workspace-root db:generate",
    "test:e2e": "jest --config jest.e2e.config.cjs --runInBand"
  },
  "dependencies": {
    "@aigateway/sdk": "workspace:*",
    "@earendil-works/pi-agent-core": "0.80.10",
    "@earendil-works/pi-ai": "0.80.10",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/terminus": "^11.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "ali-oss": "6.23.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "undici": "^7.28.0",
    "yauzl": "3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.28",
    "@types/ali-oss": "6.23.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.0",
    "@types/yauzl": "2.10.3",
    "@types/yazl": "3.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "yazl": "3.3.1"
  }
}
