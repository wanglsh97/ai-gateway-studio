# Release identity and public entry
APP_VERSION=replace-with-git-sha
DOMAIN=example.com
PUBLIC_IP=203.0.113.10
HTTP_PORT=80
SMOKE_MODEL_ALIAS=qwen

# API runtime
NODE_ENV=production
API_PORT=3001
WEB_ORIGIN=https://example.com
LOG_LEVEL=info
TRUSTED_PROXY_HOPS=1

# PostgreSQL / Redis (DATABASE_URL password must be URL-encoded)
POSTGRES_DB=aigateway
POSTGRES_USER=aigateway
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://aigateway:replace-with-url-encoded-password@postgres:5432/aigateway?schema=public
DATABASE_POOL_MAX=10
REDIS_URL=redis://redis:6379

# Provider switches. Start the first ECS deployment in Mock-only mode.
MOCK_PROVIDER_ENABLED=true
QWEN_ENABLED=false
GLM_ENABLED=false
DEEPSEEK_ENABLED=false
KIMI_ENABLED=false
WANXIANG_ENABLED=false
COGVIEW_ENABLED=false

# Provider credentials are injected only on ECS. Never commit real values.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL_ID=

GLM_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_MODEL_ID=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_ID=

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL_ID=

WANXIANG_API_KEY=
WANXIANG_BASE_URL=https://dashscope.aliyuncs.com/api/v1
WANXIANG_MODEL_ID=
COGVIEW_API_KEY=
COGVIEW_MODEL_ID=

# Feature defaults
PROMPT_OPTIMIZER_MODEL=qwen
CHAT_RATE_LIMIT_PER_MINUTE=10
IMAGE_RATE_LIMIT_PER_MINUTE=5
ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=5
ADMIN_FIXED_CREDENTIALS_ENABLED=false
ADMIN_SESSION_SECRET=replace-with-at-least-32-random-characters
ADMIN_SESSION_TTL_SECONDS=900
CHAT_MAX_TOKENS=4096
PROVIDER_TIMEOUT_MS=60000
PROVIDER_MAX_CONNECTIONS=20
